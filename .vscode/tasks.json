  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -Command \"ng serve --open\"",
      "label": "ng serve auto",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "type": "npm",
      "script": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    },
    {
      "type": "shell",
      "label": "Open Figma",
      "command": "start https://www.figma.com/design/eqUOC0Fh2PuKwG4x0kUFHh",
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
